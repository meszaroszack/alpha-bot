# ─── Kalshi API ───────────────────────────────────────────────────────────────
# API Key ID (from Kalshi account → API Keys page)
KALSHI_API_KEY=your_api_key_id_here

# Private Key (PEM format — paste the full contents of your .key file)
# Never commit this file or expose it to the frontend.
KALSHI_API_SECRET="-----BEGIN RSA PRIVATE KEY-----
...paste your private key here...
-----END RSA PRIVATE KEY-----"

# Optional: JWT secret for session tokens (defaults to dev-secret)
JWT_SECRET=your_jwt_secret_here

# ─── Supabase (persistence layer) ─────────────────────────────────────────────
# Supabase project URL — same as NEXT_PUBLIC_SUPABASE_URL in compd-trader
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Service role key — from Supabase → Project Settings → API → service_role
# This bypasses RLS so the bot can write on behalf of BOT_USER_ID.
# KEEP THIS SECRET — never expose in frontend code.
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Your Supabase auth.uid() — the user ID that owns the trades/signals/runs rows.
# Find it: Supabase → Authentication → Users → click your user → copy UUID.
BOT_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Bot model ID — "Trader Retro" model seeded in compd-trader migration 00002.
# Default value is correct unless you created a different model.
BOT_RUN_MODEL_ID=a0000000-0000-4000-8000-000000000001

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
