# Kalshi API Key ID (displayed in Kalshi account → API Keys)
# Frontend can send this; optionally set here for server-only use.
KALSHI_API_KEY=your_api_key_id_here

# Kalshi Private Key (PEM format). Paste the full contents of your .key file.
# Never commit this file or expose it to the frontend.
KALSHI_API_SECRET="-----BEGIN RSA PRIVATE KEY-----
...paste your private key here...
-----END RSA PRIVATE KEY-----"

# Optional: JWT secret for session tokens (defaults to dev-secret)
JWT_SECRET=your_jwt_secret_here

# Optional: set to "production" for live Kalshi
NODE_ENV=development
