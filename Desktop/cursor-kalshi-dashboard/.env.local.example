# Required: none — public REST endpoints work without credentials.

# Optional: WebSocket URL (defaults to production elections host).
# Public channels (ticker, trade) work without authentication in the browser.
# Private channels (orderbook_delta) require RSA-signed headers and are not
# exposed from this client; order book uses REST polling instead.
NEXT_PUBLIC_KALSHI_WS_URL=wss://api.elections.kalshi.com/trade-api/ws/v2

# Optional: disable browser WebSocket (REST + polling only).
# NEXT_PUBLIC_KALSHI_DISABLE_WS=true

# Optional: Kalshi API credentials (used if you extend the app with a server-side
# WebSocket bridge for private channels). Not read by the default UI.
# KALSHI_API_KEY_ID=your_key_id_here
# KALSHI_PRIVATE_KEY_PATH=./keys/kalshi_private_key.pem

# Optional: PEM contents (server-only) if you cannot mount a key file.
# KALSHI_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Optional: override REST base URL (demo / testing).
NEXT_PUBLIC_KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# Optional: verbose API logging in development.
NEXT_PUBLIC_DEBUG_API=false
